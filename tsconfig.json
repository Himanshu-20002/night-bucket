{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
   "typeRoots": ["./node_modules/@types", "./src/types"],
   "types":["jest"],
   "baseUrl": ".",
   "paths": {
    "@components/*": ["src/components/*"],
    "@features/*": ["src/features/*"],
    "@navigation/*": ["src/navigation/*"],
    "@assets/*": ["src/assets/*"],
    "@screens/*": ["src/screens/*"],
    "@types/*": ["src/types/*"],
    "@utils/*": ["src/utils/*"],
    "@services/*": ["src/services/*"],
    "@state/*": ["src/state/*"],
    "@styles/*": ["src/styles/*"]
   }
  }
}
